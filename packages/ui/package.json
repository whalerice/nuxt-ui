{
  "name": "@whalerice/nuxt-ui",
  "version": "0.0.1",
  "description": "Nuxt layer + local module: shadcn-vue components (CLI). No shadcn-nuxt package. Published as @whalerice/nuxt-ui.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "*.css",
    "*.vue"
  ],
  "exports": {
    ".": "./nuxt.config.ts",
    "./module": "./src/module/index.ts",
    "./style.css": "./app/assets/css/tailwind.css",
    "./lib/utils": {
      "types": "./app/lib/utils.ts",
      "import": "./app/lib/utils.ts",
      "default": "./app/lib/utils.ts"
    },
    "./components": {
      "types": "./app/components/ui/index.ts",
      "import": "./app/components/ui/index.ts",
      "default": "./app/components/ui/index.ts"
    },
    "./*": {
      "types": "./app/components/ui/*/index.ts",
      "import": "./app/components/ui/*/index.ts",
      "default": "./app/components/ui/*/index.ts"
    }
  },
  "files": [
    "app",
    "src/module",
    "nuxt.config.ts",
    "components.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:prepare": "nuxt prepare",
    "prepublishOnly": "pnpm pack --dry-run"
  },
  "dependencies": {
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.7",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue-sonner": "^2.0.9",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "nuxt": "^4.4.4",
    "tailwindcss": "^4.1.11",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "nuxt": "^4.4.4",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "vue": "^3.5.33"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whalerice/nuxt-ui.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
