{
  "name": "@whalerice/nuxt-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter docs dev",
    "build": "pnpm --filter docs build",
    "prepare:ui": "pnpm --filter @whalerice/nuxt-ui exec nuxt prepare",
    "pack:ui": "pnpm --filter @whalerice/nuxt-ui pack --dry-run",
    "publish:ui": "pnpm --filter @whalerice/nuxt-ui publish --no-git-checks"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
